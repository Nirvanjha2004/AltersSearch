# 1. LLM Router
GROQ_API_KEY=gsk_your_groq_key_here

# 2. Embeddings for Ingestion
GOOGLE_API_KEY=sk_your_google_key_here

# 3. Database (Use the Service Role Key, not the Anon Key, so your workers can bypass Row Level Security)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=ey_your_service_role_key_here

# 4. Ingestion Worker
# Needed to bypass the strict 60 requests/hour limit for unauthenticated GitHub API calls
GITHUB_TOKEN=ghp_your_github_personal_access_token_here